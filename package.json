{
  "name": "quotation-app",
  "version": "1.0.0",
  "description": "报价单管理系统",
  "author": "Chloe <2441686096@qq.com>",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:server": "node server.js",
    "dist": "electron-builder",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64 --ia32",
    "build:mac": "electron-builder --mac --x64 --arm64",
    "build:linux": "electron-builder --linux",
    "prepare": "npx cap sync"
  },
  "dependencies": {
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "puppeteer-core": "^24.4.0",
    "sqlite3": "^5.1.7",
    "@capacitor/core": "^5.0.0",
    "electron": "^28.3.3"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "@capacitor/cli": "^5.0.0"
  },
  "build": {
    "appId": "com.example.quotation",
    "npmRebuild": false,
    "asar": true,
    "files": [
      "src/**/*",
      "main.js",
      "preload.js",
      "server/**/*"
    ],
    
    "win": {
      "target": ["nsis", "portable"],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "extraFiles": [
        {
          "from": "server/database",
          "to": "database"
        }
      ]
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.business"
    },
    "linux": {
      "target": ["AppImage"]
    },
    "extraResources": [
      {
        "from": "server/database",
        "to": "database"
      },
      {
        "from": "server/uploads",
        "to": "uploads"
      }
    ]
  }
}
